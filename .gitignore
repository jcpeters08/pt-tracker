# macOS
.DS_Store

# Editor
.vscode/
.idea/

# Claude Code / local tooling (machine-local — never committed)
.claude/
.pytest_cache/

# Playwright e2e artifacts
/test-results/
/playwright-report/
/blob-report/
/.playwright/

# Python
__pycache__/
*.pyc
*.pyo
.venv/

# Node / Wrangler
/node_modules/
worker/node_modules/
worker/.wrangler/
worker/.dev.vars

# Logs
*.log

# Local secrets (PAT lives in the Worker's encrypted KV; never on disk)
.env
.env.local
*.pat
